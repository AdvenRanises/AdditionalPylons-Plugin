<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyName>AdditionalPylons</AssemblyName>
    <RootNamespace>AdditionalPylons</RootNamespace>
    <Version>2.0.0</Version>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Point these to your actual TShock 6.1 server files -->
  <ItemGroup>
    <Reference Include="OTAPI">
      <HintPath>..\..\TShock\OTAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="TerrariaServer">
      <HintPath>..\..\TShock\TerrariaServer.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="TShockAPI">
      <HintPath>..\..\TShock\ServerPlugins\TShockAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="TerrariaApi.Server">
      <HintPath>..\..\TShock\ServerPlugins\TerrariaServer.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
